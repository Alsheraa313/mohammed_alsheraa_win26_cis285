// README at: https://github.com/devcontainers/templates/tree/main/src/universal
{
    "name": "Default Linux Universal",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "postCreateCommand": "cd /workspaces && npx --yes create-next-app@latest frontend --js --no-tailwind --no-eslint --no-src-dir --app --no-import-alias --yes && mkdir -p backend && cd backend && npm init -y && npm install express cors"
}

